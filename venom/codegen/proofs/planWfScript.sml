(*
 * Plan well-formedness: prefix_wf for code generator output
 *
 * Proves that ops generated by generate_regular_inst_plan's
 * prefix (before the final SOEmit) satisfy prefix_wf,
 * enabling prefix_sim to establish AsmOK.
 *
 * Key results:
 *   - prefix_wf_append: composition of prefix_wf sequences
 *   - prefix_wf_every_prefix_op: prefix_wf implies EVERY is_prefix_op
 *   - stack_find_bound: stack_find results are within bounds
 *   - prefix_wf_spills/restores: prefix_wf for bulk spill/restore
 *   - do_swap_wf, do_dup_wf, etc: per-operation wf
 *   - regular_plan_prefix_wf_gen: the main result
 *)


Theory planWf
Ancestors
  prefixExec prefixSim stackPlanOps stackPlanGen stackModel stackPlanTypes codegenRel asmIR list rich_list arithmetic pair option
Libs
  BasicProvers

(* ===== Basic prefix_wf properties ===== *)

Theorem prefix_wf_nil[simp]:
  !lo n. prefix_wf lo n []
Proof
  simp[prefix_wf_def]
QED

Theorem prefix_end_len_nil[simp]:
  !lo n. prefix_end_len lo n [] = n
Proof
  simp[prefix_end_len_def]
QED

Theorem prefix_wf_append:
  !xs ys lo n.
    prefix_wf lo n xs /\
    prefix_wf lo (prefix_end_len lo n xs) ys ==>
    prefix_wf lo n (xs ++ ys)
Proof
  Induct >> simp[prefix_wf_def, prefix_end_len_def] >>
  rpt gen_tac >> pairarg_tac >> simp[] >> metis_tac[]
QED

Theorem prefix_end_len_append:
  !xs ys lo n.
    prefix_end_len lo n (xs ++ ys) =
    prefix_end_len lo (prefix_end_len lo n xs) ys
Proof
  Induct >> simp[prefix_end_len_def] >>
  rpt gen_tac >> simp[prefix_end_len_def] >>
  pairarg_tac >> simp[]
QED

Theorem prefix_wf_every_prefix_op:
  !ops lo n. prefix_wf lo n ops ==> EVERY is_prefix_op ops
Proof
  Induct >> simp[prefix_wf_def] >>
  rpt gen_tac >> pairarg_tac >> simp[] >>
  rpt strip_tac >>
  Cases_on `h` >> fs[stack_op_wf_def, is_prefix_op_def] >>
  metis_tac[]
QED

Theorem prefix_wf_cons:
  !op rest lo n.
    prefix_wf lo n (op :: rest) <=>
    (let (ok, n') = stack_op_wf lo op n in
     ok /\ prefix_wf lo n' rest)
Proof
  simp[prefix_wf_def]
QED

Theorem prefix_wf_single:
  !op lo n. prefix_wf lo n [op] <=> FST (stack_op_wf lo op n)
Proof
  rpt gen_tac >> simp[prefix_wf_def] >>
  pairarg_tac >> simp[]
QED

(* prefix_end_len for single ops *)
Theorem prefix_end_len_single:
  !op lo n. prefix_end_len lo n [op] = SND (stack_op_wf lo op n)
Proof
  rpt gen_tac >> simp[prefix_end_len_def] >>
  pairarg_tac >> simp[]
QED

(* prefix_end_len for concrete ops *)
Theorem prefix_end_len_spill[simp]:
  !lo off n. prefix_end_len lo n [SOSpill off] = n - 1
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

Theorem prefix_end_len_restore[simp]:
  !lo off n. prefix_end_len lo n [SORestore off] = n + 1
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

Theorem prefix_end_len_swap[simp]:
  !lo k n. prefix_end_len lo n [SOSwap k] = n
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

Theorem prefix_end_len_dup[simp]:
  !lo k n. prefix_end_len lo n [SODup k] = n + 1
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

Theorem prefix_end_len_push_lit[simp]:
  !lo v n. prefix_end_len lo n [SOPush (Lit v)] = n + 1
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

Theorem prefix_end_len_poke[simp]:
  !lo i op n. prefix_end_len lo n [SOPoke i op] = n
Proof
  simp[prefix_end_len_def, stack_op_wf_def]
QED

(* ===== stack_find / stack_get_depth bounds ===== *)

Theorem stack_find_bound:
  !p xs d. stack_find p xs = SOME d ==> d < LENGTH xs
Proof
  Induct_on `xs` >> simp[stack_find_def] >>
  rpt gen_tac >> IF_CASES_TAC >> simp[] >>
  Cases_on `stack_find p xs` >> simp[] >>
  strip_tac >> gvs[] >> res_tac >> simp[]
QED

Theorem stack_get_depth_bound:
  !op stk d.
    stack_get_depth op stk = SOME d ==> d < LENGTH stk
Proof
  rpt strip_tac >>
  fs[stack_get_depth_def] >>
  imp_res_tac stack_find_bound >>
  fs[LENGTH_REVERSE]
QED

(* ===== Bulk spill/restore prefix_wf ===== *)

(* A list of k SOSpill ops is prefix_wf when starting stack >= k *)
Theorem prefix_wf_spills:
  !offs lo n.
    LENGTH offs <= n ==>
    prefix_wf lo n (MAP SOSpill offs) /\
    prefix_end_len lo n (MAP SOSpill offs) = n - LENGTH offs
Proof
  Induct >> simp[] >>
  rpt gen_tac >> strip_tac >>
  simp[prefix_wf_def, prefix_end_len_def, stack_op_wf_def] >>
  first_x_assum (qspecl_then [`lo`, `n - 1`] mp_tac) >>
  simp[]
QED

(* A list of k SORestore ops is always prefix_wf *)
Theorem prefix_wf_restores:
  !offs lo n.
    prefix_wf lo n (MAP SORestore offs) /\
    prefix_end_len lo n (MAP SORestore offs) = n + LENGTH offs
Proof
  Induct >> simp[] >>
  rpt gen_tac >>
  simp[prefix_wf_def, prefix_end_len_def, stack_op_wf_def] >>
  first_x_assum (qspecl_then [`lo`, `n + 1`] mp_tac) >> simp[]
QED

